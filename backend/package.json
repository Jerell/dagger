{
  "name": "dagger-backend",
  "version": "0.1.0",
  "type": "module",
  "description": "Bun/Elysia API server for Dagger network inspection",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "start": "bun src/index.ts",
    "test": "bun test",
    "test:costing": "bun test src/services/costing/",
    "test:costing:integration": "bun test src/services/costing/*.integration.test.ts",
    "test:services": "bun test src/services/*.test.ts",
    "build:wasm": "cd ../cli && wasm-pack build --target nodejs --out-dir ../backend/pkg",
    "build:wasm:release": "cd ../cli && wasm-pack build --release --target nodejs --out-dir ../backend/pkg"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "effect": "^3.19.19",
    "elysia": "^1.4.27"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
